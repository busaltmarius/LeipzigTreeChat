{
  "name": "qanary-component-sparql-generation",
  "version": "1.0.0",
  "description": "A simple Qanary component to generate and execute SPARQL queries.",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "bun build --target bun --outdir dist src/index.ts",
    "clean": "rimraf .turbo dist node_modules",
    "dev": "bun --env-file=.env --watch src/index.ts",
    "format": "prettier --check src",
    "format:fix": "prettier --write src",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "bun run build --workspace=@leipzigtreechat/qanary-api && bun run build --workspace=@leipzigtreechat/shared && bun run build --workspace=@leipzigtreechat/qanary-component-core && bun test --coverage"
  },
  "dependencies": {
    "@leipzigtreechat/qanary-api": "workspace: *",
    "@leipzigtreechat/qanary-component-core": "workspace: *",
    "@leipzigtreechat/qanary-component-helpers": "workspace: *",
    "@leipzigtreechat/shared": "workspace: *",
    "node-geocoder": "^4.4.1",
    "proj4": "^2.20.4"
  },
  "devDependencies": {
    "@leipzigtreechat/typescript-config": "workspace: *",
    "@types/node-geocoder": "^4.2.6",
    "@types/proj4": "^2.19.0",
    "bun-types": "^1.3.6",
    "openapi-types": "12.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^4.9.5"
  }
}
