      "types": "./src/state/index.ts",
      "default": "./dist/state/index.js"
    }
  },
  "devDependencies": {
    "@leipzigtreechat/typescript-config": "workspace: *",
    "@types/bun": "^1.3.8",
    "rimraf": "^6.1.3",
    "typescript": "latest"
  },
  "dependencies": {
    "@leipzigtreechat/qanary-component-helpers": "workspace: *",
    "@effect/platform": "^0.94.1",
    "@langchain/core": "^1.1.12",
    "@langchain/langgraph": "^1.0.14",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "ai": "^6.0.27",
    "effect": "^3.19.14"
  }
