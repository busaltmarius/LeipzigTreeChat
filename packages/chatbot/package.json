{
  "name": "@leipzigtreechat/chatbot",
  "type": "module",
  "scripts": {
    "benchmark:demo": "bun src/__benchmarks__/index.ts",
    "dev": "tsc --watch",
    "build": "tsc",
    "clean": "rimraf .turbo dist node_modules",
    "test": "bun test src/**/*.spec.ts",
    "tsdoc": "bun ../../scripts/generate-package-tsdoc.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
